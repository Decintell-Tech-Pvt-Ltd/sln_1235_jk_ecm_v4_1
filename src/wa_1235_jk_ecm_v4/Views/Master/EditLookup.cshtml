
@using Microsoft.AspNetCore.Http
@using System.Text.Json
@inject IHttpContextAccessor HttpContextAccessor
@model wa_1235_jk_ecm_v4.Models.Master

@{
    ViewData["Title"] = "ValueStream";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}
<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-3">
                    <h5>Edit</h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#" onclick="UserDetailChange('Index')">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">ECM</a></li>
                        <li class="breadcrumb-item active">Master</li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Lookup", "Master", new { PageID = Context.Request.Query["PageID"], ParentID = Context.Request.Query["ParentID"], ModuleID = Context.Request.Query["ModuleID"] })">Lookup</a></li>

                        <li class="breadcrumb-item">Add</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button"
                                class="btn btn-block bg-gradient-danger btn-xs"
                                onclick="window.history.back()"
                                title="Go back to the previous page">
                            Back
                        </button>
                    </div>

                </div>
            </div>
        </div><!-- /.container-fluid -->

    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">

                    <div class="card card-outline card-primary">
                        <!-- /.card-header -->
                        <div class="card-body">


                            <div class="row">


                                <div class="form-group col-md-2">
                                    <label>Product Line</label>

                                    @Html.DropDownListFor(m => m.ProdId, new SelectList(Model.ProdLine_List, "ProductLineCode", "ProductLine"), "Select", new { @class = "form-control select2", @id = "ddlproductline", onchange = "clearError('spddlproductline')",disabled="disabled" })
                                    <span id="spddlproductline" class="text-danger"></span>


                                </div>
                                <div class="col-md-2 form-group">
                                    <label>Lookup Type </label>
                                    @Html.DropDownListFor(
                                        m => m.LookupTypeId,
                                        new SelectList(Model.LookupTypes_List, "LookupTypeId", "LookupType"),
                                        "Select",
                                        new {
                                            @class = "form-control select2",
                                            @id = "ddlLookuptype",
                                            onchange = "toggleAddNewType(); clearError('spddlLookuptype')",disabled="disabled" 
                                        })                                    <span id="spddlLookuptype" class="text-danger"></span>

                                </div>

                              @*   <div class="col-md-2 form-group">
                                    <label>Add New Type</label>
                                    <input id="txtAddNewType" type="text" class="form-control"  disabled />
                                      <span id="sptxtAddNewType" class="text-danger"></span>
                                </div> *@

                                <div class="col-md-2 form-group">
                                    <label>Lookup Value</label>
                                    <input  type="text" class="form-control" id="txtLookupValue">
                                       <span id="sptxtLookupValue" class="text-danger"></span>
                                </div>


                                <div class="col-md-3 form-group">
                                    <label>Image File Upload</label>
                                    <div class="input-group">
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" id="exampleInputFile">
                                            <label class="custom-file-label" for="exampleInputFile">Choose file</label>
                                       
                                        </div>

                                    </div>
                                      <input id="hdBrandId" name="" type="hidden" value="@ViewBag.BrandId" type="text" class="form-control">
                                </div>

                                <div style="margin-top:35px;">
                                    <a type="button" onclick="SubmitLookupData()" id="btnSubmitLookup" class="btn btn-primary btn-xs btnwidth50" href="#">
                                        Submit
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>


        </div>


        <!-- /.content -->

    </section>

    <!-- InstanceEndEditable -->
</div>
<script>
    var lookupData = @Html.Raw(
        JsonSerializer.Serialize(
            Model.LookUp_MasterData?.FirstOrDefault()
        )
    );
    function BindLookupData() {

    if (!lookupData) return;

    // ⭐ Product Line dropdown
    $("#ddlproductline")
        .val(lookupData.ProductLineCode)
        .trigger("change");
    $('#hdBrandId').val(lookupData.LookupId);

    // ⭐ Lookup Type dropdown
    $("#ddlLookuptype")
        .val(lookupData.LookupTypeId)
        .trigger("change");

    // ⭐ Lookup Value textbox
    $("#txtLookupValue").val(lookupData.LookupValue);

    // ⭐ Add New Type (optional)
    if (lookupData.AddNewType != null &&
        lookupData.AddNewType !== "") {

        $("#txtAddNewType")
            .prop("disabled", false)
            .val(lookupData.AddNewType);
    }

    // ⭐ Image file label (cannot set file input)
    if (lookupData.ImageFileName) {
        $(".custom-file-label")
            .text(lookupData.ImageFileName);
    }
}
$(document).ready(function () {

    BindLookupData();

});
</script>
<script>
    $(document).ready(function () {

    // Add Add New option
    $("#ddlLookuptype").append(
        $('<option>', {
            value: "ADD_NEW",
            text: "Add New"
        })
    );

    // Disable textbox initially
    $("#txtAddNewType").prop("disabled", true);
});
function toggleAddNewType() {

    var selectedValue = $("#ddlLookuptype").val();

    if (selectedValue === "ADD_NEW") {
        $("#txtAddNewType").prop("disabled", false);
        $("#txtAddNewType").focus();
    } else {
        $("#txtAddNewType").prop("disabled", true);
        $("#txtAddNewType").val("");
    }
}
function SubmitLookupData() {

    var productLine = $("#ddlproductline").val();
    var lookupType = $("#ddlLookuptype option:selected").text();
    var lookupTypeId = $("#ddlLookuptype").val();
    var addNewType = $("#txtAddNewType").val().trim();
    var lookupValue = $("#txtLookupValue").val().trim();
    var hdBrandId = $("#hdBrandId").val();
    // ⭐ Get file name only
    var fileInput = document.getElementById("exampleInputFile");
    var imageName = "";

    if (fileInput.files.length > 0) {
        imageName = fileInput.files[0].name;   // e.g. a1.jpg
    }

    var createdBy = parseInt('@Context.Session.GetInt32("CreatedBy")');

    var validation = false;

    // ---------- Validation ----------
    if (!productLine) {
        $("#spddlproductline").text("Select Product Line");
        validation = true;
    } else {
        $("#spddlproductline").text("");
    }

    if (!lookupTypeId) {
        $("#spddlLookuptype").text("Select Lookup Type");
        validation = true;
    } else {
        $("#spddlLookuptype").text("");
    }

    if (lookupValue === "") {
         $("#sptxtLookupValue").text("Enter Lookup Value");
        validation = true;
    }
    else {
        $("#sptxtLookupValue").text("");
    }
    if (validation) return;

    // ---------- JSON ----------
    let json = {
        LookupId:hdBrandId,
        ProductLine: productLine,
        LookupType: lookupTypeId,
        AddNewType: addNewType,
        LookupName: lookupValue,

        // ⭐ IMAGE NAME ADDED
        ImageName: imageName,

        CreatedBy: createdBy,
        OperationFlag: 2
    };

    var JsonData = JSON.stringify(json);

    // ---------- API Call ----------
    $.ajax({
        type: "POST",
        url: '@Url.Action("AddLookupData", "Master")',
        data: { JsonData: JsonData },
        datatype: "json",

        beforeSend: function () {
            $('#loader').show();
        },
        complete: function () {
            $('#loader').hide();
        },

        success: function (response) {
            alert(response.response);
           var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
    var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
    var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
    var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

    // Construct the full URL
    var url = '@Url.Action("Lookup", "Master")' +
        '?PageID=' + pageID +
        '&ParentID=' + parentID +
        '&ModuleID=' + moduleID +
        '&ModulePageID=' + modulePageID;

    // Redirect to the URL
    window.location.href = url;
        },

        error: function () {
            alert("Error while saving lookup data");
        }
    });
}
</script>