<script>
        function LoadOperations(ProductLine,val_valuestream_code,val_valuestream_name,operations) {

             // Set header values
    $("#txtProductline").text(ProductLine);
    $("#txtValueStreamCode").text(val_valuestream_code);
    $("#txtValueStreamName").text(val_valuestream_name);

        var tbody = $("#tblOperationsBody");
        tbody.empty();

        if (!operations) return;

        var ops = operations.split(",");

        for (var i = 0; i < ops.length; i++) {

            var parts = ops[i].split("-");

            var sqNo = parts[0].trim();
            var opName = parts[1].trim();

            var row = "<tr>" +
                "<td align='center'>" + sqNo + "</td>" +
                "<td>" + opName + "</td>" +
                "</tr>";

            tbody.append(row);
        }
    }
</script>