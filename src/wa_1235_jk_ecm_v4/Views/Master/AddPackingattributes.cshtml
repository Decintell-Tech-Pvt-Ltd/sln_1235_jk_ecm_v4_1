@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "ValueStream";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}
<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-3">
                    <h5>Add </h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="../login/marketing-page.html">Home</a></li>
                        <li class="breadcrumb-item"><a href="index.html">ECM</a></li>
                        <li class="breadcrumb-item">Masters</li>
                        <li class="breadcrumb-item"><a href="Packing-Attributes.html">Packing Attributes</a></li>
                        <li class="breadcrumb-item">Add</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button" class="btn btn-block bg-gradient-danger btn-xs float-left"
                                onclick="location.href='Packing-Attributes.html'" title="Go back to the previous page">
                            Back
                        </button>
                    </div>

                </div>

            </div><!-- /.container-fluid -->

    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
                    <div class="card card-primary card-outline p-a-2" style="height: 100%;">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="col-md-12">

                                <div class="row">

                                    <div class="form-group col-md-2">
                                        <label for="">Product Line</label>
                                        <select class="form-control select2">
                                            <option>Select</option>
                                            <option>DRILLS </option>
                                            <option>TAPS </option>
                                            <option>DIES </option>

                                        </select>
                                    </div>

                                    <div class="form-group col-md-2">
                                        <label>Attributes</label>
                                        <select name="" class="form-control select2">
                                            <option>Select</option>
                                            <option>Add New</option>
                                            <option>Blackodising </option>
                                            <option>Hologram</option>
                                            <option>Line No.</option>
                                            <option>Quality Seal </option>
                                            <option> Tang Tempering</option>
                                            <option>Tang Color</option>

                                        </select>

                                    </div>

                                    <div class="form-group col-md-2">
                                        <label>New Attribute </label>
                                        <input id="txtCustomerCode" type="text" maxlength="2" class="form-control" disabled />
                                        <span id="sptxtCustomerCode" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-3">
                                        <label>Attribute Value</label>
                                        <input id="txtCustomer" maxlength="50" name="" type="text" class="form-control" />
                                        <span id="sptxtCustomer" class="text-danger"></span>
                                    </div>

                                    <div class="btnwidth50 float-right mr-1 " style="margin-top:35px;">
                                        <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
                                                onclick="location.href='Packing-Attributes.html'" title="Go to the next page">
                                            Submit
                                        </button>
                                    </div>


                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </section>




    <!-- InstanceEndEditable -->
</div>