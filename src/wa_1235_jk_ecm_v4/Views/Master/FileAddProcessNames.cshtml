@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model wa_1235_jk_ecm_v4.Models.Master
@{
    ViewData["Title"] = "StampMaster";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}
<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-3">
                    <h5>Add</h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#" onclick="UserDetailChange('Index')">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">ECM</a></li>
                        <li class="breadcrumb-item active">Master</li>
                        <li class="breadcrumb-item active">Files</li>
                        <li class="breadcrumb-item"><a href="@Url.Action("FileProcessNames", "Master", new { PageID = Context.Request.Query["PageID"].ToString(), ParentID = Context.Request.Query["ParentID"].ToString(), ModuleID = Context.Request.Query["ModuleID"].ToString(), ModulePageID = Context.Request.Query["ModulePageID"].ToString() })">Process Names</a></li>
                        <li class="breadcrumb-item active">Add</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button" class="btn btn-block bg-gradient-danger btn-xs float-left"
                                onclick="location.href='Files-Process-Names.html'" title="Go back to the previous page">
                            Back
                        </button>
                    </div>

                </div>

            </div><!-- /.container-fluid -->

    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <div class="card card-primary card-outline p-a-2">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="col-md-12">

                                <div class="row">


                                    <div class="form-group col-md-3">
                                        <label for="">Product Line</label><br>
                                        <span class="mt-1" style="display: block;">Files</span>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <label>Sequence  </label>
                                        <input id="txtSequence" type="number" class="form-control" oninput="clearError('spSequence');" />
                                        <span id="spSequence" class="text-danger"></span>
                                    </div>



                                    <div class="form-group col-md-7">
                                        <label for="">Process Name</label>
                                        <input type="text" id="txtProcessName" maxlength="200" class="form-control" oninput="clearError('spProcessName');" />
                                        <span id="spProcessName" class="text-danger"></span>

                                    </div>

                                    <div class="form-group col-md-12">
                                        <div class="btnwidth50 float-right mr-1">
                                            <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
                                                    onclick="AddProcess();" title="Go to the next page">
                                                Submit
                                            </button>
                                        </div>
                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </section>




    <!-- InstanceEndEditable -->
</div>

<script>
            function clearError(id) {
            $("#" + id).text("");
        }



        function AddProcess() {

        var isValid = true;

        var Sequence = $('#txtSequence').val();
        var ProcessName = $('#txtProcessName').val();
     
        // Validation
        if (!Sequence || Sequence.trim() === "") {
            $('#spSequence').text("Please Enter Sequence");
            isValid = false;
        }

        if (!ProcessName || ProcessName.trim() === "") {
            $('#spProcessName').text("Please Enter Process Name");
            isValid = false;
        }

       
        if (!isValid) return false;

        var json = {
            Sequence: Sequence,
            ProcessName: ProcessName
        };
         var JsonData = JSON.stringify(json);

        $.ajax({
             type: "POST",
            url: '@Url.Action("FileProcessAdd", "Master")',
            data: { JsonData: JsonData },
            datatype: 'json',
            success: function (data) {

                alert(data.response);

                var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
                var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
                var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
                var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

                var url = "@Url.Action("FileProcessNames", "Master")" +
                    "?PageID=" + pageID +
                    "&ParentID=" + parentID +
                    "&ModuleID=" + moduleID +
                    "&ModulePageID=" + modulePageID;

                window.location.href = url;
            }
        });
    }
</script>