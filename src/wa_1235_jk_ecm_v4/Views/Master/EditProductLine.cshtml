@using Microsoft.AspNetCore.Http
@using System.Text.Json
@inject IHttpContextAccessor HttpContextAccessor
@model wa_1235_jk_ecm_v4.Models.Master
@{
    ViewData["Title"] = "EditBrand";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}
<div class="content-wrapper">
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-3">
                <h5> Product Line</h5>
            </div>
            <div class="col-lg-9">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#" onclick="UserDetailChange('Index')">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">ECM</a></li>
                    <li class="breadcrumb-item active">Master</li>
                    <li class="breadcrumb-item"><a href="@Url.Action("ProductLine", "Master", new { PageID = Context.Request.Query["PageID"].ToString(), ParentID = Context.Request.Query["ParentID"].ToString(), ModuleID = Context.Request.Query["ModuleID"].ToString(), ModulePageID = Context.Request.Query["ModulePageID"].ToString() })">Product Line</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="btnwidth50 float-right ">
                    @{
                        var url = Url.Action("ProductLine", "Master", new
                        {
                            PageID = Context.Request.Query["PageID"].ToString(),
                            ParentID = Context.Request.Query["ParentID"].ToString(),
                            ModuleID = Context.Request.Query["ModuleID"].ToString(),
                            ModulePageID = Context.Request.Query["ModulePageID"].ToString()
                        });
                    }
                    <button type="button"
                            class="btn btn-block bg-gradient-danger btn-xs float-left"
                            onclick="location.href='@url'"
                            title="Go back to the previous page">
                        Back
                    </button>
                </div>

            </div>

        </div><!-- /.container-fluid -->
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline p-a-2" style="height: 100%;">

                    <!-- /.card-header -->
                    <div class="card-body">
                        @{
                            var brand = Model.EditProductLineLists?.FirstOrDefault();
                        }
                        <div class="col-md-12">

                            <div class="row">

                                <div class="form-group col-md-2">
                                    <label>Product Code  </label>
                                    @* <input id="txtCustomerCode" type="text" maxlength="2" class="form-control" />
                                    <span id="sptxtCustomerCode" class="text-danger"></span> *@
                                    <input id="txtProductCode" type="text" class="form-control" maxlength="2" oninput="validateInputCode()">
                                    <span id="spProductCode" class="text-danger" style="display:none;"></span>
                                </div>
                                <div class="form-group col-md-4">
                                    <label>Product Name  </label>
                                    @*   <input id="txtCustomer" maxlength="50" name="" type="text" class="form-control" />
                                    <span id="sptxtCustomer" class="text-danger"></span> *@
                                    <input id="txtProductName" type="text" class="form-control" oninput="validateInput(event)">
                                    <span id="spProductName" class="text-danger"></span>
                                </div>
                                <div style="display: none;">
                                    <input id="hdBrandId" name="" type="hidden" value="@ViewBag.Id"  class="form-control">
                                </div>

                                <div class="btnwidth50 float-right mr-1 " style="margin-top:35px;">
                                    <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left" id="btn_EditSubmitBrand"
                                            onclick="AddBrandData();" title="Add new record">
                                        Submit
                                    </button>
                                </div>


                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- /.card -->
        </div>
    </div>
</section>
</div>
<script>
    var BrandData = {
        brandId: '@brand?.ProductId',
        brandName: '@brand?.ProductLine',
        brandCode: '@brand?.ProductLineCode',
      
    };
        function bindBrandData() {

        $('#txtProductName').val(BrandData.brandName);
        $('#txtProductCode').val(BrandData.brandCode);
        $('#hdBrandId').val(BrandData.brandId);

        // ProductLine dropdown bind
        
    }

    $(document).ready(function () {

     
        bindBrandData();
    });
</script>
<script>


    function validateInputCode() {
        var inputElement = document.getElementById('txtProductCode');
        var errorElement = document.getElementById('spProductCode');
        var inputValue = inputElement.value;

        // Allow only letters and digits
        var filteredInput = inputValue.replace(/[^a-zA-Z0-9]/g, '');

        // Update the input field
        inputElement.value = filteredInput;

        // Validation logic
        if (filteredInput.length === 2 || filteredInput === '') {
            errorElement.innerText = '';
            errorElement.style.display = 'none';
        } else {
            errorElement.innerText = 'Only two characters/digits are allowed.';
            errorElement.style.display = 'inline';
        }
    }


    var ValidationFlag = true;

    $(document).ready(function () {
        $('#txtProductCode').on('input', function () {
            var inputValue = $(this).val();

            if (/\s/.test(inputValue)) {
                $("#spProductCode").html("Spaces not allowed in Product Code");
                $("#spProductCode").css("display", "block");
                ValidationFlag = true;
                return;
            }
            else {
                $("#spProductCode").html("");
                //  ValidationFlag = false;
            }

            // Perform your check here, for example, check if the input value is not empty
            if (inputValue.trim() !== '') {
                // Data exists in the textbox
                // You can perform an AJAX call here
                $.ajax({
                    url: '@Url.Action("GetExistingProductList", "Master")',
                    type: 'GET', // Or 'GET', depending on your requirement
                    data: { term: inputValue }, // Pass data to the server
                    success: function (response) {
                        if (response != null && response.length > 0) {
                            if (response[0].label != null) {
                               alert("Product Code already exists");
                                ValidationFlag = true;
                                return;
                            }
                            else {
                                $("#spProductCode").html("");
                                //   ValidationFlag = false;
                            }
                        }
                        else {
                            $("#spProductCode").html("");
                            // ValidationFlag = false;
                        }
                    },
                    error: function (xhr, status, error) {
                        // Handle errors here
                        alert('Error occurred:', error);
                    }
                });
            } else {
                // Data doesn't exist in the textbox
                $("#spProductCode").html("Enter Product Code");
                $("#spProductCode").css("display", "block");
                ValidationFlag = true;
                return;
            }
        });
    });




    txtProductName.addEventListener("input", function (event) {
        // Get the current value of the input field
        var inputValue = event.target.value;

        // Check if the entered value is a blank
        if (inputValue.trim() == '') {
            $("#spProductName").html("Enter Product Name");
            $("#spProductName").css("display", "block");
            ValidationFlag = true;
            return;
        }

        else {
            $("#spProductName").html("");
            //  ValidationFlag = false;
        }
    });



    function AddBrandData() {
        var ProductName = $("#txtProductName").val().trim();
        var ProductCode = $("#txtProductCode").val();

        var hdBrandId = $("#hdBrandId").val();

        //alert(BrandName + "," + BrandCode);
        var OperationFlag = 2;
        ValidationFlag = false;


        var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');


      if (ProductName == "") {
            $("#spProductName").html("Enter Product Name");
            $("#spProductName").css("display", "block");
            ValidationFlag = true;
        }
        else {
            $("#spProductName").html("");
        }


        if (ProductCode == "") {
            $("#spProductCode").html("Enter Product Code");
            $("#spProductCode").css("display", "block");
            ValidationFlag = true;
        }
        else {
            if ($("#spProductCode").html() == "")
                $("#spProductCode").html("");
        }


       if ($("#spProductName").text() == "" && $("#spProductCode").text() == "")  {

           



            let json = {
                Id: hdBrandId,
                ProductLine: ProductName.trim(),
                ProductLineCode: ProductCode.trim().toUpperCase(),
               
                OperationFlag: OperationFlag
                //CustomerDetailsJarr: DiscountSlabsJson
            };

            var JsonData = JSON.stringify(json);
            $.ajax({
                type: "POST",
                url: '@Url.Action("AddProduct", "Master")',
                data: { JsonData: JsonData },
                datatype: 'json',
                beforeSend: function () { $('#loader').show(); }, complete: function () { $('#loader').hide(); },
                success: function (data) {
                    alert(data.response);

                     var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
    var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
    var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
    var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

    // Construct the full URL
    var url = '@Url.Action("ProductLine", "Master")' +
        '?PageID=' + pageID +
        '&ParentID=' + parentID +
        '&ModuleID=' + moduleID +
        '&ModulePageID=' + modulePageID;

    // Redirect to the URL
    window.location.href = url;
                }


            });

        }
    }


</script>