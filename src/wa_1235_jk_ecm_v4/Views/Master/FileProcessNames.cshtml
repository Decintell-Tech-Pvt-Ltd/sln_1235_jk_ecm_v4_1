@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model wa_1235_jk_ecm_v4.Models.Master
@{
    ViewData["Title"] = "ValueStream";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}


<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-3">
                    <h5>Process Names</h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#" onclick="UserDetailChange('Index')">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">ECM</a></li>
                         <li class="breadcrumb-item active">Master</li>
                        <li class="breadcrumb-item active">Files</li>
                        <li class="breadcrumb-item active">Process Names</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button"
                                class="btn btn-block bg-gradient-danger btn-xs"
                                onclick="window.history.back()"
                                title="Go back to the previous page">
                            Back
                        </button>
                    </div>
                    <div class="btnwidth50 float-right mr-1">
                        <a class="btn btn-block bg-gradient-primary btn-xs float-left"
                           href="@Url.Action("FileAddProcessNames", "Master", new { PageID = Context.Request.Query["PageID"].ToString(), ParentID = Context.Request.Query["ParentID"].ToString(), ModuleID = Context.Request.Query["ModuleID"].ToString(), ModulePageID = Context.Request.Query["ModulePageID"].ToString() })"
                           title="Add new record">
                            Add
                        </a>
                    </div>
                </div>
            </div>
        </div><!-- /.container-fluid -->

    </section>

    <section class="content">

        <div class="container-fluid">


            <div class="row">
                <div class="col-md-12">
                    <div class="card card-outline card-primary">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <div>
                                <div class="table-responsive">
                                    <table class="table table-bordered example1">
                                        <thead>
                                            <tr>
                                                <th width="30%"><div align="left">Product Line​</div></th>
                                                <th width="20%"><div align="center">Sequence</div></th>
                                                <th width="40%"><div align="left">Process Name</div></th>
                                                <th width="2%">
                                                    <div align="center">Delete</div>
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            
                                            @if (Model.FileTypeProcess_List != null)
                                            {
                                                @foreach (var item in Model.FileTypeProcess_List)
                                                {
                                                    <tr>

                                                        <td>@item.ProductLine</td>
                                                        <td style="text-align:center;">

                                                            @item.ParamCatSeq

                                                        </td>

                                                        <td style="white-space: normal;">

                                                            @item.ParamCatName

                                                        </td>

                                                        <td class="text-center">
                                                            <a class="btn btn-danger btn-xs" title="Delete" onclick="DeleteProcess(@item.Id)">
                                                                Delete
                                                            </a>
                                                        </td>
                                                    </tr>


                                                }

                                            }
                                            </tbody>

                                       
                                        
                                    </table>
                                </div>

                            </div>
                            <!-- /.tab-pane -->





                        </div>
                        <!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>

            </div>


    </section>


    <!-- InstanceEndEditable -->
</div>
<script>
      function DeleteProcess(Id) {

        if (confirm("Are you sure you want to delete this record?")) {

            let json = {
                ProcessID: Id
            };

            var JsonData = JSON.stringify(json);

            $.ajax({
                url: '@Url.Action("DeleteFileProcess", "Master")',
                type: 'POST',
                data: { JsonData: JsonData },

                success: function (response) {

                         alert(response.response);
                        location.reload();


                },
                error: function () {
                    alert("Error occurred while deleting");
                }
            });

        }
    }

</script>