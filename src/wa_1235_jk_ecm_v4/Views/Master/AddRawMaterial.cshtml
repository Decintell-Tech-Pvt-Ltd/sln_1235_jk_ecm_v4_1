@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "ValueStream";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}
<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-3">
                    <h5>Add</h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                         <li class="breadcrumb-item"><a href="#" onclick="UserDetailChange('Index')">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">ECM</a></li>
                          <li class="breadcrumb-item active">Master</li>
                        <li class="breadcrumb-item"><a href="@Url.Action("RawMaterial", "Master", new { PageID = Context.Request.Query["PageID"].ToString(), ParentID = Context.Request.Query["ParentID"].ToString(), ModuleID = Context.Request.Query["ModuleID"].ToString(), ModulePageID = Context.Request.Query["ModulePageID"].ToString() })">Raw Material</a></li>
                        <li class="breadcrumb-item">Add</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button" 
        class="btn btn-block bg-gradient-danger btn-xs float-left"
        onclick="location.href='@Url.Action("RawMaterial", "Master", new { 
            PageID = Context.Request.Query["PageID"].FirstOrDefault(), 
            ParentID = Context.Request.Query["ParentID"].FirstOrDefault(), 
            ModuleID = Context.Request.Query["ModuleID"].FirstOrDefault(), 
            ModulePageID = Context.Request.Query["ModulePageID"].FirstOrDefault() 
        });'" 
        title="Go back to the previous page">
    Back
</button>
                    </div>

                </div>

            </div><!-- /.container-fluid -->

    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
                    <div class="card card-primary card-outline p-a-2" style="height: 100%;">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="col-md-12">

                                <div class="row">

                                    <div class="form-group col-md-2">
                                        <label for="">Product Line</label>
                                        <select class="form-control select2">
                                            <option>Select</option>
                                            <option>DRILLS </option>
                                            <option>TAPS </option>
                                            <option>DIES </option>

                                        </select>
                                    </div>


                                    <div class="form-group col-md-2">
                                        <label>Raw Material Code  </label>
                                        <input id="txtCustomerCode" type="text" maxlength="2" class="form-control" />
                                        <span id="sptxtCustomerCode" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>Raw Material Description</label>
                                        <input id="txtCustomer" maxlength="50" name="" type="text" class="form-control" />
                                        <span id="sptxtCustomer" class="text-danger"></span>
                                    </div>

                                    <div class="btnwidth50 float-right mr-1 " style="margin-top:35px;">
                                        <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
                                                onclick="location.href='Raw-Material.html'" title="Go to the next page">
                                            Submit
                                        </button>
                                    </div>


                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </section>




    <!-- InstanceEndEditable -->
</div>