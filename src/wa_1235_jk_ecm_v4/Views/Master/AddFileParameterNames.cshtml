@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model wa_1235_jk_ecm_v4.Models.Master
@{
    ViewData["Title"] = "ValueStream";
    Layout = "~/Views/Shared/_ECMMaster.cshtml";
}




<div class="content-wrapper">
    <!-- InstanceBeginEditable name="EditRegion1" -->


    <section class="content-header">
   
            <div class="row">
                <div class="col-lg-3">
                    <h5>Add</h5>
                </div>
                <div class="col-lg-9">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="../login/marketing-page.html">Home</a></li>
                        <li class="breadcrumb-item"><a href="index.html">ECM</a></li>
                        <li class="breadcrumb-item">Masters</li>
                        <li class="breadcrumb-item">Files</li>
                        <li class="breadcrumb-item"><a href="Files-Parameter-Names.html">Parameter Names</a></li>
                        <li class="breadcrumb-item">Add</li>
                    </ol>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btnwidth50 float-right ">
                        <button type="button" class="btn btn-block bg-gradient-danger btn-xs float-left"
                                onclick="location.href='Files-Parameter-Names.html'" title="Go back to the previous page">
                            Back
                        </button>
                    </div>

                </div>

            </div><!-- /.container-fluid -->

    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <div class="card card-primary card-outline p-a-2">

                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="col-md-12">

                                <div class="row">



                                    <div class="form-group col-md-6">
                                        <label for="">Process Name</label>
                                        @Html.DropDownListFor(m => m.ProdId, new SelectList(Model.FileTypeProcess_List, "Id", "ParamCatName"), "Select", new { @class = "form-control select2", @id = "ddlProcess", onchange = "clearError('spddlProcess');" })
                                        <span id="spddlProcess" class="text-danger"></span>

                                    </div>

                                    <div class="form-group col-md-6">
                                        <label>Parameter Name  </label>
                                        <input type="text" id="txtParameterName" maxlength="200"  class="form-control" oninput="clearError('spParameterName');" />
                                        <span id="spParameterName" class="text-danger"></span>

                                    </div>


                                    <div class="form-group col-md-3">
                                        <label>Parameter Code  </label>
                                        <input type="text" id="txtParameterCode" maxlength="3" class="form-control" oninput="clearError('spParameterCode');" />
                                        <span id="spParameterCode" class="text-danger"></span>

                                    </div>



                                    <div class="form-group col-md-2">
                                        <label>UOM  </label>
                                        <select class="form-control select2" id="ddlUOM" onchange="clearError('spdllUOM');">
                                            <option>Select</option>
                                            <option value="mm">mm</option>
                                            <option value="cm">cm</option>
                                            <option value="inch">inch</option>

                                        </select>
                                        <span id="spdllUOM" class="text-danger"></span>

                                    </div>



                                    <div class="form-group col-md-2">
                                        <label>Input Type  </label>
                                        <input type="number" id="txtInputType"
                                               class="form-control"
                                               oninput="clearError('spInputType');" /> 
                                               <span id="spInputType" class="text-danger"></span>

                                    </div>


                                    <div class="btnwidth50 float-right mr-1 " style="margin-top:34px;">
                                        <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
                                                onclick="AddPrarameter();" title="Go to the next page">
                                            Submit
                                        </button>
                                    </div>


                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </section>




    <!-- InstanceEndEditable -->
</div>

<script>
            function clearError(id) {
            $("#" + id).text("");
        }



        function AddPrarameter() {

        var isValid = true;

        var Process = $('#ddlProcess').val();
        var Parameter = $('#txtParameterName').val();
        var ParameterCode = $('#txtParameterCode').val();
        var Uom = $('#ddlUOM').val();
        var InputType = $('#txtInputType').val();

        // Validation
        if (!Process || Process === "Select") {
            $('#spddlProcess').text("Please select process");
            isValid = false;
        }

        if (!Parameter || Parameter.trim() === "") {
            $('#spParameterName').text("Please enter parameter name");
            isValid = false;
        }

        if (!ParameterCode || ParameterCode.trim() === "") {
            $('#spParameterCode').text("Please enter parameter code");
            isValid = false;
        }

        if (!Uom) {
            $('#spddlUOM').text("Please select UOM");
            isValid = false;
        }

        if (!InputType) {
            $('#spInputType').text("Please enter input type");
            isValid = false;
        }

        if (!isValid) return false;

        var json = {
            Process: Process,
            ParameterName: Parameter,
            ParameterCode: ParameterCode,
            InputType: InputType,
            UOM: Uom 
        };
         var JsonData = JSON.stringify(json);

        $.ajax({
             type: "POST",
            url: '@Url.Action("FileParameterAdd", "Master")',
            data: { JsonData: JsonData },
            datatype: 'json',
            success: function (data) {

                alert(data.response);

                var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
                var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
                var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
                var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

                var url = "@Url.Action("FileParameterNames", "Master")" +
                    "?PageID=" + pageID +
                    "&ParentID=" + parentID +
                    "&ModuleID=" + moduleID +
                    "&ModulePageID=" + modulePageID;

                window.location.href = url;
            }
        });
    }
</script>
