<script>
        function loadTypeByProductLine(selectedTypeId = null) {

        var productLineId = $('#ddlproductline').val();

        // Reset Type dropdown
        $('#TxtFileType').empty();
        $('#TxtFileType').append('<option value="">Select</option>');

        if (!productLineId || productLineId === "0") {
            return;
        }

        var jsonData = {
            ProductLineRowId: productLineId
        };

        $.ajax({
            url: '@Url.Action("GetCTTypeData", "DrillMaster")',
            type: 'POST',
            data: {
                JsonData: JSON.stringify(jsonData)
            },

            success: function (data) {

                if (data && data.response) {

                    $.each(data.response, function (index, item) {

                        $('#TxtFileType').append(
                            $('<option>', {
                                value: item.id,
                                text: item.ctTypeName,
                                'data-code': item.ctTypeCode
                            })
                        );

                    });
                     if (selectedTypeId) {

                        $('#TxtFileType')
                            .val(selectedTypeId)
                            .trigger('change');

                    }
                    $('#TxtFileType').trigger('change.select2');
                }
            },

            error: function (xhr) {
                console.log("Error loading Type:", xhr.responseText);
            }
        });
    }
        function SubmitForApproval() {

        // 🔹 Get type code (TY / JB etc)
        
        var FileType = $("#TxtFileType option:selected").text().trim();

    // Extract TY from "Cutting -TY"
        var FileTypeCode = FileType.split('-').pop().trim();
        if (!FileType) {
            alert("Type Code not found.");
            return;
        }

        var iLoggedInUserID =
            parseInt('@Context.Session.GetInt32("CreatedBy")');

        var jsonData = JSON.stringify({
            CTTypeCode: FileTypeCode,
            StatusName: "PendingForApproval",
            CreatedBy: iLoggedInUserID,
            Remark: ""
        });

        $.ajax({
            type: "POST",
            url: '@Url.Action("UpdateTypeStatus", "DrillMaster")',
            data: { JsonData: jsonData },
            dataType: "json",

            beforeSend: function () {
                $('#loader').show();
            },

            complete: function () {
                $('#loader').hide();
            },

            success: function (data) {

                if (data && data.response === "Status Updated Successfully") {

                    alert("Submitted for approval successfully.");

                    // redirect (optional)
                    location.reload();
                }
                else {
                    alert(data.response || "Something went wrong.");
                }
            },

            error: function (xhr) {
                alert("Error while updating status.");
                console.error(xhr.responseText);
            }
        });
    }
        function onTypeChange() {

        var selectedOption = $('#TxtFileType option:selected');

        var fileCode = selectedOption.data("code");

        $("#hdnFileCode").val(fileCode);

        console.log("Selected File Code:", fileCode);
    }
        $("#btnAdd").click(function () {
        readCSVFile();
    });
           function readCSVFile() {

        var fileInput = document.getElementById("FileUploadCSV");

        if (fileInput.files.length === 0) {
            alert("Please select CSV file.");
            return;
        }

        var file = fileInput.files[0];
        var reader = new FileReader();

        reader.onload = function (e) {

            var csv = e.target.result;

            // split lines safely
            var rows = csv.split(/\r?\n/);

            var table = $('#tblCSVData').DataTable();

            table.clear();

            for (var i = 1; i < rows.length; i++) {

                if (!rows[i].trim()) continue;

                // basic split
                var cols = rows[i].split(",");

                if (cols.length < 8) continue;

                table.row.add([
                    cols[0]?.trim() || "",
                    cols[1]?.trim() || "",
                    cols[2]?.trim() || "",
                    cols[3]?.trim() || "",
                    cols[4]?.trim() || "",
                    cols[5]?.trim() || "",
                    cols[6]?.trim() || "",
                    cols[7]?.trim() || ""
                ]);
            }

            table.draw();
        };

        reader.readAsText(file);
    }
