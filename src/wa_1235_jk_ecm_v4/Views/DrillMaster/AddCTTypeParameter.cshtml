        function convertJSONToCSV() {
        var FileTypeId = $('#ddlFileTypeCVS').val();
        var FileTypeName = $('#ddlFileTypeCVS option:selected').text().trim(); // Get text for filename

        var JsonData = JSON.stringify({
            ID: FileTypeId
        });

        $.ajax({
            type: "POST",
            url: '@Url.Action("CT_GetTypeParametersList", "DrillMaster")',
            data: { JsonData: JsonData },
            dataType: 'json',
            beforeSend: function () { $('#loader').show(); },
            complete: function () { $('#loader').hide(); },
            success: function (data) {
                var JsonData1 = data.response;
                var JsonData = JSON.stringify({
                    JsonData: JsonData1
                });

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("DownloadExcel", "Master")',
                    data: { JsonData: JsonData },
                    xhrFields: {
                        responseType: 'blob'
                    },
                    success: function (response) {
                        const blob = new Blob([response], { type: 'text/csv' });
                        const url = window.URL.createObjectURL(blob);
                        const link = document.createElement('a');

                        // Set filename based on dropdown text (sanitize if needed)
                        const fileName = FileTypeName.replace(/[^\w\-]/g, '_') + '.csv';

                        link.href = url;
                        link.setAttribute('download', fileName);
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        window.URL.revokeObjectURL(url); // Clean up blob URL
                    },
                    error: function (xhr, status, error) {
                        console.error("Error occurred:", error);
                        alert("An error occurred while downloading the file.");
                    }
                });
            },
            error: function () {
                alert('Error occurred while fetching data.');
            }
        });
    }


