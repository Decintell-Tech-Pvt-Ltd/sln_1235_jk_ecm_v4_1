         function EditSaveData() {

        var FileType = $('#TxtFileType option:selected').text().trim();
        let productLineText = $("#ddlproductline option:selected").text();

        var FileTypeCode = FileType.split('-').pop().trim();

        var filenameCSV = ($('#FileUploadCSV')[0].files[0])
            ? $('#FileUploadCSV')[0].files[0].name
            : $("#FileUploadCSV").next(".custom-file-label").text();

        var fileInput = document.getElementById('FileUploadCSV');

        //-----------------------------------------
        // IF NEW CSV UPLOADED
        //-----------------------------------------

        if (fileInput.files.length > 0) {

            var file = fileInput.files[0];
            var reader = new FileReader();

            reader.onload = function (event) {

                var csvContent = event.target.result;
                var jsonArray = csvToJson(csvContent);

                // ===== HEADER NORMALIZATION (same as SaveData) =====

                function normalizeKey(key) {
                    return key.replace(/[\s_\-]/g, '').toLowerCase().trim();
                }

                function getValue(obj, keys) {
                    for (let k of keys) {
                        let nk = normalizeKey(k);
                        if (obj[nk] !== undefined)
                            return obj[nk];
                    }
                    return "";
                }

                function toBit(val) {
                    if (!val) return 0;
                    val = val.toString().toLowerCase().trim();
                    return (val == "1" || val == "yes" || val == "true") ? 1 : 0;
                }

                var detailRows = jsonArray.map(row => {

                    let normalized = {};

                    Object.keys(row).forEach(k => {
                        normalized[normalizeKey(k)] = row[k];
                    });

                    return {

                        ProcessSequence: getValue(normalized, [
                            "Process Sequence",
                            "ProcessSequence"
                        ]),

                        ProcessName: getValue(normalized, [
                            "ProcessName"
                        ]),

                        ParamName: getValue(normalized, [
                            "ParamName"
                        ]),

                        ParamCode: getValue(normalized, [
                            "ParamCode"
                        ]),

                        ParamUOM: getValue(normalized, [
                            "ParamUOM"
                        ]),

                        Range: toBit(getValue(normalized, ["Range"])),
                        Nominal: toBit(getValue(normalized, ["Nominal"])),
                        KeyDimension: toBit(getValue(normalized, ["KeyDimension"]))
                    };
                });

                sendUpdate(detailRows, filenameCSV);
            };

            reader.readAsText(file);
        }

        //-----------------------------------------
        // IF NO CSV UPLOADED → USE OLD DATA
        //-----------------------------------------
        else {

            sendUpdate(existingCSVRows, filenameCSV);
        }
    }

    function sendUpdate(detailRows, filenameCSV) {

        var FileType = $("#TxtFileType option:selected").text().trim();
        var FileTypeCode = FileType.split('-').pop().trim();

        var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');

        var finalJson = {

            TxnId: '@Context.Request.Query["TypeId"]',

            CsvFileName: filenameCSV,
            ProductLine: $("#ddlproductline option:selected").text(),
            CTTypeCode: FileTypeCode,

            CreatedBy: iLoggedInUserID,

            Details: detailRows
        };

        console.log("UPDATE JSON =>", finalJson);

        $.ajax({
            type: "POST",
            url: '@Url.Action("InsertCSVTypeDetails", "DrillMaster")',
            data: { JsonData: JSON.stringify(finalJson) },
            dataType: 'json',

            beforeSend: function () { $('#loader').show(); },
            complete: function () { $('#loader').hide(); },

            success: function (data) {

                if (data && data.response === "Insert Successfully") {

                    alert("Updated Successfully");

                    var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
                    var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
                    var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');

                    var url = '@Url.Action("CTTypeParameter", "DrillMaster")'
                        + '?PageID=' + pageID +
                        '&ParentID=' + parentID +
                        '&ModuleID=' + moduleID;

                    window.location.href = url;
                }
                else {
                    alert(data.response || "Error occurred while updating.");
                }
            },

            error: function (xhr) {
                console.error(xhr.responseText);
                alert("Error occurred while updating.");
            }
        });
    }
