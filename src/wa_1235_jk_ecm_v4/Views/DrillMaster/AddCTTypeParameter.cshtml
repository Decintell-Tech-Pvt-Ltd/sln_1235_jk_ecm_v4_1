    function CutSideTabledata() {
        // Get selected values from dropdowns
        var selectedCutSides = $("#TxtCutSide").val();
        var selectedCutOnSides = $("#TxtCutonside").val();

        // Clear existing table rows
        $("#TableCutSide tbody").empty();

        // Check if at least one option is selected from both dropdowns
        if (selectedCutSides.length > 0 && selectedCutOnSides.length > 0) {
            // Loop through each selected Cut Side
            selectedCutSides.forEach(function (cutSideID) {
                var cutSideName = $("#TxtCutSide option[value='" + cutSideID + "']").text();

                // Loop through each selected Cut On Side
                selectedCutOnSides.forEach(function (cutOnSideID) {
                    var cutOnSideName = $("#TxtCutonside option[value='" + cutOnSideID + "']").text();

                    var row = "<tr>";
                    row += "<td>" + cutSideName + "</td>";
                    row += "<td style='display:none;'>" + cutSideID + "</td>";
                    row += "<td>" + cutOnSideName + "</td>";
                    row += "<td style='display:none;'>" + cutOnSideID + "</td>";

                    // Create delete button icon
                    var deleteIconLink = $('<a></a>').attr('href', '#').addClass('fa-i-small redbt top10');
                    deleteIconLink.append($('<img>').attr('src', '../decintell/icons/delete.png').addClass('img-responsive'));
                    var deleteIconDiv = $('<div></div>').css({ 'margin-left': 'auto', 'margin-right': 'auto', 'float': 'none', 'display': 'table' });
                    deleteIconDiv.append(deleteIconLink);
                    var deleteButtonCell = $('<td align="center"></td>').append(deleteIconDiv);
                    row += deleteButtonCell.prop('outerHTML'); // Append delete button cell HTML to the row

                    row += "</tr>";

                    $("#TableCutSide tbody").append(row);
                });
            });
        } else {
            alert("Please select at least one option from both dropdowns.");
        }
    }

</script>

