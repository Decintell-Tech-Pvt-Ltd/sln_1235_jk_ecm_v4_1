        var file = fileInput.files[0];

        var reader = new FileReader();

        reader.onload = function (event) {

            var csvContent = event.target.result;
            var jsonArray = csvToJson(csvContent);

            // ===== HEADER NORMALIZATION =====
            function normalizeKey(key) {
                return key.replace(/[\s_\-]/g, '').toLowerCase().trim();
            }

            function getValue(obj, keys) {
                for (let k of keys) {
                    let nk = normalizeKey(k);
                    if (obj[nk] !== undefined)
                        return obj[nk];
                }
                return "";
            }

            function toBit(val) {
                if (!val) return 0;
                val = val.toString().toLowerCase().trim();
                return (val == "1" || val == "yes" || val == "true") ? 1 : 0;
            }

            // ===== BUILD CSV ROW JSON =====
            var detailRows = jsonArray.map(row => {

                let normalized = {};

                Object.keys(row).forEach(k => {
                    normalized[normalizeKey(k)] = row[k];
                });

                return {

                    ProcessSequence: getValue(normalized, [
                        "Process Sequence",
                        "ProcessSequence"
                    ]),

                    ProcessName: getValue(normalized, [
                        "ProcessName"
                    ]),

                    ParamName: getValue(normalized, [
                        "ParamName"
                    ]),

                    ParamCode: getValue(normalized, [
                        "ParamCode"
                    ]),

                    ParamUOM: getValue(normalized, [
                        "ParamUOM"
                    ]),

                    Range: toBit(getValue(normalized, ["Range"])),
                    Nominal: toBit(getValue(normalized, ["Nominal"])),
                    KeyDimension: toBit(getValue(normalized, ["KeyDimension"]))
                };
            });

            // ===== FINAL JSON WRAPPER =====
            var finalJson = {

                CsvFileName: filenameCSV,
                ProductLine: productLineText,
                CTTypeCode: FileTypeCode,

                Details: detailRows
            };

            console.log("FINAL JSON =>", finalJson);

            $.ajax({
                type: "POST",
                url: '@Url.Action("InsertCSVTypeDetails", "DrillMaster")',
                data: { JsonData: JSON.stringify(finalJson) },
                dataType: "json",
                beforeSend: function () { $('#loader').show(); },
                complete: function () { $('#loader').hide(); },

                success: function (data) {

                    if (data && data.response === "Insert Successfully") {
                        alert("Type added successfully.");

                        window.location.href =
                            '@Url.Action("CTTypeParameter", "DrillMaster")';
                    }
                    else {
                        alert(data.response || "Error");
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                    alert("Error while saving.");
                }
            });

        };

        reader.readAsText(file);
    }

