      // Function to convert CSV to JSON
    function csvToJson(csv) {
        // Split the CSV by newlines to get each row
        var lines = csv.split("\n");

        // Get the headers from the first row
        var headers = lines[0].split(",");

        var jsonArray = [];

        // Loop through the remaining lines to convert each to a JSON object
        for (var i = 1; i < lines.length; i++) {
            var line = lines[i].trim();

            // Skip empty lines
            if (line === "") continue;

            var values = line.split(",");
            var jsonObject = {};

            // Assign the values to the appropriate headers
            for (var j = 0; j < headers.length; j++) {
                jsonObject[headers[j].trim()] = values[j] ? values[j].trim() : null;
            }

            // Push the JSON object to the array
            jsonArray.push(jsonObject);
        }

        return jsonArray;
    }

