<script>
    function SaveSizeData() {

    // success message
    alert("Size details saved successfully");

    // redirect
    var url = '@Url.Action("DrillSize", "DrillMaster")' +
        '?PageID=' + pageID +
        '&ParentID=' + parentID +
        '&ModuleID=' + moduleID;

    window.location.href = url;
}
    function LoadCTSizeTable() {

    let productLineId = $("#ddlproductline").val();
    let ctTypeRowId = $("#TxtFileType").val();

    if (!productLineId || productLineId == "0") return;
    if (!ctTypeRowId || ctTypeRowId == "0") return;

    let jsonData = {
        ProductLineRowId: productLineId,
        CTTypeRowId: ctTypeRowId
    };

    $.ajax({
        type: "POST",
        url: '@Url.Action("GetCTSizeDetails","DrillMaster")',
        data: { JsonData: JSON.stringify(jsonData) },
        dataType: "json",

        success: function (res) {

            let tbody = $("#tblCTSizeBody");
            tbody.empty();

            if (!res || !res.response || res.response.length === 0)
                return;

            res.response.forEach(function (item) {

                let row = `
                <tr>
                    <td><div align="center">${item.id}</div></td>
                    <td><div align="left">${item.productLineName}</div></td>
                    <td><div align="left">${item.ctTypeName}</div></td>
                    <td><div align="left">${item.paramName || ''}</div></td>
                    <td><div align="center">${item.paramCode || ''}</div></td>
                    <td><div align="left">${item.paramType || ''}</div></td>
                    <td><div align="left">${item.sizeUOM || ''}</div></td>
                    <td><div align="center">${item.sizeValue || ''}</div></td>
                    <td>
                        <div align="center">
                            <a href="#" class="Edit">${item.sizeCode}</a>
                        </div>
                    </td>
                </tr>`;

                tbody.append(row);
            });
        },
        error: function () {
            alert("Error loading table");
        }
    });
}
        function AddCTSizeData() {

        let isValid = true;

        // Read values
        let ProductLineRowId = $("#ddlproductline").val();
        let CTTypeRowId = $("#TxtFileType").val();
        let SizeValue = $("#txtSizeValue").val();
        let SizeCode = $("#spSizeCode").text();
        let SizeUOM = $("#ddlUOM").val();

        let iLoggedInUserID =
            parseInt('@Context.Session.GetInt32("CreatedBy")');

        let OperationFlag = 1;
           
       
        // ---------- VALIDATION ----------
        if (!ProductLineRowId || ProductLineRowId == "0") {
            alert("Please select Product Line");
            isValid = false;
        }

        if (!CTTypeRowId || CTTypeRowId == "0") {
            alert("Please select Type");
            isValid = false;
        }

        if (!SizeValue) {
            alert("Please enter Size Value");
            isValid = false;
        }

        if (!SizeUOM) {
            alert("Please select UOM");
            isValid = false;
        }

        if (!isValid) return;

        // ---------- JSON OBJECT ----------
        let jsonData = {
            ProductLineRowId: ProductLineRowId,
            CTTypeRowId: CTTypeRowId,
            SizeCode: SizeCode,
            SizeValue: SizeValue,
            SizeUOM: SizeUOM,
            CreatedBy: iLoggedInUserID,
            OperationFlag: OperationFlag,
            CreatedDate: moment.utc(new Date()).format()

         
        };

        // ---------- AJAX CALL ----------
        $.ajax({
            type: "POST",
            url: '@Url.Action("AddCTSize", "DrillMaster")',
            data: {
                JsonData: JSON.stringify(jsonData)
            },
            dataType: "json",

            beforeSend: function () {
                $('#loader').show();
            },
            complete: function () {
                $('#loader').hide();
            },

            success: function (res) {

                alert(res.response || "Saved Successfully");

                // Reload page (optional)
                location.reload();
            },

            error: function () {
                alert("Error while saving.");
            }
        });
    }
        function generateSizeCode() {

        let val = $("#txtSizeValue").val();

        if (!val) {
            $("#spSizeCode").text("");
            return;
        }

        // Convert to number
        let num = parseFloat(val);

        if (isNaN(num)) {
            $("#spSizeCode").text("");
            return;
        }

        // Multiply by 100
        let code = Math.round(num * 100);

        // Pad to 4 digits
        let finalCode = code.toString().padStart(4, '0');

        $("#spSizeCode").text(finalCode);
    }
        $(document).ready(function () {

        $('#TxtFileType').on('change', function () {
            onTypeChange();
        });

