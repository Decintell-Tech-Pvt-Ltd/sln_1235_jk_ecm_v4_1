<script>

       function validateInputCode() {

        let input = document.getElementById('txtDimensionCode');
        let value = input.value.replace(/\D/g, ''); // digits only

        // Limit to 4 digits
        if (value.length > 4) {
            value = value.substring(0, 4);
            document.getElementById('sptxtDimensionCode').innerText =
                'Only 4 digits are allowed.';
        } else {
            document.getElementById('sptxtDimensionCode').innerText = '';
        }

        input.value = value;
    }

        function LoadEditFileSize(SizeId) {

        let json = {
            TxnId: SizeId
        };

        $.ajax({
            type: "POST",
            url: '@Url.Action("GetDroFileSizeListById", "DrillMaster")',
            data: { JsonData: JSON.stringify(json) },
            dataType: "json",
            beforeSend: function () { $('#loader').show(); },
            complete: function () { $('#loader').hide(); },
            success: function (res) {

                if (!res || !res.response || res.response.length === 0) {
                    alert("No data found");
                    return;
                }

                let data = res.response[0];

                // Store Id
                $("#hdnSizeId").val(data.id);

                // Bind controls
                $("#ddlproductline").val(data.productLineRowId).trigger("change");
                $("#TxtFileType").val(data.ctTypeRowId).trigger("change");
                $("#txtSizeValue").val(data.sizeValue);
               $("#spSizeCode").text(data.sizeCode);
           
                    // 🔒 Disable controls
    $("#ddlproductline").prop("disabled", true);
    
 
    $("#TxtFileType").prop("disabled", true);
                // UI change
                $("#btnsubmit")
                    .text("Submit")
                    .attr("onclick", "EditFileSizeData()");
            },
            error: function () {
                alert("Error loading data");
            }
        });
    }
        $(document).ready(function () {
        let editId = '@Context.Request.Query["SizeId"]';
        if (editId) {
            LoadEditFileSize(editId);
        }
    });
     

</script>