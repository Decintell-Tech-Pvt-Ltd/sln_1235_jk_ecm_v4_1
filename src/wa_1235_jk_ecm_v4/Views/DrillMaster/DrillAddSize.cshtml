                                    <table class="table table-bordered example1 nowrap" style="width:100%;"  id="tblCTSize">
                                        <thead>

                                            <tr>
                                                <th width="10%"><div align="center">Request No.</div></th>
                                                <th width="15%"><div align="left">Product Line</div></th>
                                                <th width="25%"><div align="left">Type</div></th>
                                                <th width="10%">
                                                    <div align="left">
                                                        Key <br />
                                                        Parameter
                                                    </div>
                                                </th>
                                                <th width="10%">
                                                    <div align="center">
                                                        Key <br />
                                                        Parameter Code
                                                    </div>
                                                </th>
                                                <th width="10%">
                                                    <div align="left">
                                                        Key <br />
                                                        Parameter Type
                                                    </div>
                                                </th>
                                                <th width="6%"><div align="left">UOM</div></th>
                                                <th width="6%">
                                                    <div align="center">
                                                        Size <br />
                                                        Value
                                                    </div>
                                                </th>
                                                <th width="10%">
                                                    <div align="center">Size<br> Code</div>
                                                </th>
                                            </tr>
                                        </thead>
                                       <tbody id="tblCTSizeBody">
</tbody>
                                    </table>
                                </div>

                                <div class=" float-right ml-1 " style="margin-top:35px; display:none;">
                                    <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
