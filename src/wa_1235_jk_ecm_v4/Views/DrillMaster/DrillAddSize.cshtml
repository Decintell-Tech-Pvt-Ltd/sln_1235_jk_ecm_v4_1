                                        Submit for Approval
                                    </button>
                                </div>


                                <div class=" float-right ml-2 " style="margin-top:35px; display:block;">
                                    <button type="button" class="btn btn-block bg-gradient-primary   btn-xs float-left"
                                            onclick="SaveSizeData()" title="Go to the next page">
                                        Save
                                    </button>
                                </div>




                            </div>
                        </div>
                    </div>
                    Note: Size Code should be unique
                </div>
                <input id="hdnSizeId" type="hidden" />

                <!-- /.card -->
            </div>
        </div>
    </section>



    <!-- InstanceEndEditable -->
</div>
