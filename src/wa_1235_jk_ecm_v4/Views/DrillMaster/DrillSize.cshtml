<Script>
  function ModelFileSize(RequestId, ProductLineName, TypeName, ProductLineRowId, CTTypeRowId) {

    $('#txtID').val(RequestId);
    $('#txtRequest').text(RequestId);
    $('#txtProdLine1').text(ProductLineName);
    $('#txtType1').text(TypeName);

    var JsonData = JSON.stringify({
        ProductLineRowId: parseInt(ProductLineRowId),
        CTTypeRowId: parseInt(CTTypeRowId)
    });

    $.ajax({
        type: "POST",
        url: '@Url.Action("GetSizeDetailsByTypeAndProductLine", "DrillMaster")',
        data: { JsonData: JsonData },
        dataType: "json",

        beforeSend: function () {
            $('#loader').show();
        },
        complete: function () {
            $('#loader').hide();
        },

        success: function (data) {

            var rows = "";

            if (data.response && data.response.length > 0) {

                $.each(data.response, function (i, item) {

                    rows += "<tr>";
                    rows += "<td align='center'>" + item.sizeUOM + "</td>";
                    rows += "<td align='center'>" + item.sizeValue + "</td>";
                    rows += "<td align='center'>" + item.sizeCode + "</td>";
                    rows += "</tr>";

                });

            } else {

                rows = "<tr><td colspan='3' align='center'>No Data Found</td></tr>";

            }

            $("#sizeApproveTableBody").html(rows);

            $('#approve').modal('show');
        },

        error: function () {
            alert("Error occurred while fetching size details.");
        }
    });
}
function ModelFileType(RequestId, ProductLineName, TypeName, ProductLineRowId, CTTypeRowId,Remark) {

    $('#txtRequest1').text(RequestId);
    $('#txtProdLine').text(ProductLineName);
    $('#txtType').text(TypeName);
        $('#txtremarklbl').text(Remark);
    

    var JsonData = JSON.stringify({
        RequestId:RequestId,
        ProductLineRowId: parseInt(ProductLineRowId),
        CTTypeRowId: parseInt(CTTypeRowId)
    });

    $.ajax({
        type: "POST",
        url: '@Url.Action("GetSizeDetailsByTypeAndProductLine", "DrillMaster")',
        data: { JsonData: JsonData },
        dataType: "json",

        beforeSend: function () {
            $('#loader').show();
        },
        complete: function () {
            $('#loader').hide();
        },

        success: function (data) {

    let table = $('#sizeTable');

    // ✅ Destroy old DataTable
    if ($.fn.DataTable.isDataTable('#sizeTable')) {
        table.DataTable().clear().destroy();
    }

    let rows = "";

    if (data.response && data.response.length > 0) {

        $.each(data.response, function (i, item) {

            rows += "<tr>";
            rows += "<td class='text-center'>" + item.sizeUOM + "</td>";
            rows += "<td class='text-center'>" + item.sizeValue + "</td>";
            rows += "<td class='text-center'>" + item.sizeCode + "</td>";
            rows += "</tr>";

        });

    } else {

        rows = "<tr><td colspan='3' class='text-center'>No Data Found</td></tr>";
    }

    $("#sizeTableBody").html(rows);

    // ✅ Initialize DataTable with CSV
    let dt = table.DataTable({
        responsive: true,
        paging: true,
        pageLength: 10,
        searching: true,
        ordering: true,
        info: true,
        autoWidth: false,

        // ⭐ CSV layout
        dom: "<'row'<'col-sm-2'l><'col-sm-4 text-center'B><'col-sm-6'f>>" +
             "<'row'<'col-sm-12'tr>>" +
             "<'row'<'col-sm-5'i><'col-sm-7'p>>",

        buttons: [
            {
                extend: 'csv',
                text: 'CSV',
                className: 'btn btn-secondary btn-sm'
            }
        ]
    });

    // ✅ Fix modal table width
    $('#view').off('shown.bs.modal').on('shown.bs.modal', function () {
        dt.columns.adjust();
    });

    // ✅ Show modal
    $('#view').modal('show');
},

        error: function () {
            alert("Error occurred while fetching size data.");
        }
    });
}
    function ApprovesFileSize(ID) {
        var Remark = $('#txtRemark').val();
        var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
        
        let jsonData = { ID: ID, StatusID: 2, CreatedBy: iLoggedInUserID, Remark: Remark };
        var JSONInformation = JSON.stringify(jsonData);
        $.ajax({
            type: 'POST',
            url: '@Url.Action("DroApproveFileSize", "DrillMaster")',
            data: { JSONData: JSONInformation },
            dataType: 'json',
            success: function (data) {
                alert(data.response);
                window.location.reload();
            },
            error: function (err) {
                alert(err.statusText);
            }
        });
    }


    function ApproveFileSize() {
        var Remark = $('#txtRemark').val();
        var FileStatus = $('#txtID').val();
        var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
         

        var jsonData = { ID: FileStatus, StatusID: 3, CreatedBy: iLoggedInUserID, Remark: Remark };
        var JSONInformation = JSON.stringify(jsonData);

        $.ajax({
            type: 'POST',
            url: '@Url.Action("DroApproveFileSize", "DrillMaster")', // Assuming this URL is correctly configured in your application
            data: { JSONData: JSONInformation },
            dataType: 'json',
            success: function (data) {
                alert(data.response);
                window.location.reload();
            },
            error: function (err) {
                alert(err.statusText);
            }
        });
    }
    //RejectFileSize
    function RejectFileSize() {
        //textRemark
        var Remark = $('#txtRemark').val();

        var FileStatus = $('#txtID').val();
        var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
         

        var jsonData = { ID: FileStatus, StatusID: 4, CreatedBy: iLoggedInUserID, Remark: Remark };
        var JSONInformation = JSON.stringify(jsonData);

        $.ajax({
            type: 'POST',
            url: '@Url.Action("DroApproveFileSize", "DrillMaster")', // Assuming this URL is correctly configured in your application
            data: { JSONData: JSONInformation },
            dataType: 'json',
            success: function (data) {
                alert(data.response);
                window.location.reload();
            },
            error: function (err) {
                alert(err.statusText);
            }
        });
    }


</Script>