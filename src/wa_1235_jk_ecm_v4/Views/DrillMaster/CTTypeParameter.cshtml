	function setApproveItems(itemId) {
		document.getElementById('approveItemId').textContent = itemId;

		ModelFileSize(itemId);
		//  OpenDocument(BrandCode, ImageFile, 'displayImage1');
	}

	function EditFileType(RequestNo) {

		// Constructing the URL using JavaScript
		 var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
	var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
	var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
	var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

	// Construct the full URL
	var url = '@Url.Action("AddCTTypeParameter", "DrillMaster")' +
		'?TypeId=' + encodeURIComponent(RequestNo) +
		'&PageID=' + pageID +
		'&ParentID=' + parentID +
		'&ModuleID=' + moduleID ;

	// Redirect
	window.location.href = url;
	}



	function ApproveFileType(Id, StatusId) {
		var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
		var Remark=$('#txtRemark').val();
		var json = {
			Id: Id,
			StatusId: StatusId,
			Remark:Remark,
			CreatedDate: moment.utc(new Date()).format(),
			CreatedBy: iLoggedInUserID
		};
		var JsonData = JSON.stringify(json);


		$.ajax({
			type: "POST",
			url: '@Url.Action("DroApproveFileType", "DrillMaster")',
			data: { JsonData: JsonData },
			datatype: 'json',
			beforeSend: function () { $('#loader').show(); }, complete: function () { $('#loader').hide(); },
			success: function (data) {
				alert(data.response);
				location.reload();
			}
		});
	}




	function ModelOperation(ValueStreamCode, Id) {
		var JsonData = JSON.stringify({
			valuestreamcode: ValueStreamCode,
			id: Id
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetDroOperationList", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: 'json',
			beforeSend: function () { $('#loader').show(); },
			complete: function () { $('#loader').hide(); },
			success: function (data) {

				var html = '';


				for (var i = 0; i < data.operationList.length; i++) {
					html += '<tr>';
					html += '<td align="center">' + data.operationList[i].seqNo + '</td>';
					html += '<td align="center">' + data.operationList[i].opr_operation_name + '</td>';
					html += '</tr>';
				}
				$('#showAddedValueStreamProcess').html(html);
				$('#vscode').modal('show');
			},
			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}

		function ModelFileSize(TypeId) {

		let json = {
			TxnId: TypeId
		};

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetTypeParameterListById", "DrillMaster")',
			data: { JsonData: JSON.stringify(json) },
			dataType: "json",
			beforeSend: function () { $('#loader').show(); },
			complete: function () { $('#loader').hide(); },

			success: function (res) {

				if (!res || !res.response || res.response.length === 0) {
					alert("No data found");
					return;
				}

				let data = res.response[0];

				//--------------------------------
				// Bind Header
				//--------------------------------

				$("#txtID").val(data.typeDetailsRowId);
				$("#txtRequest").text(data.productLineCode);
				$("#txtFileName").text(data.ctTypeName);
				$("#txtFileTypeCode").text(data.ctTypeCode);
				$("#txtProdLine").text(data.productLine);

				//--------------------------------
				// Bind Image
				//--------------------------------

				if (data.imageFileName) {
					OpenDocument(data.imageFileName, 'displayImage1', data.productLine);
				}

				//--------------------------------
				// Destroy old DataTable
				//--------------------------------

				if ($.fn.DataTable.isDataTable('#tblshowAddedProcessParameters')) {
					$('#tblshowAddedProcessParameters').DataTable().clear().destroy();
				}

				//--------------------------------
				// Initialize DataTable
				//--------------------------------

				var dt = $('#tblshowAddedProcessParameters').DataTable({
					columnDefs: [
						{ className: "dt-center", targets: "_all" }
					]
				});

				//--------------------------------
				// Bind Rows
				//--------------------------------

				if (data.typeParamsJarr && data.typeParamsJarr.length > 0) {

					for (var i = 0; i < data.typeParamsJarr.length; i++) {

						var p = data.typeParamsJarr[i];

						dt.row.add([
							'<div align="center">' +  p.processSequence+ '</div>',
							'<div align="left">' + p.processName + '</div>',
							'<div align="left">' + p.paramName + '</div>',
							'<div align="center">' + p.paramUOM + '</div>'
						]).draw(false);
					}
				}

				//--------------------------------
				// Show Modal
				//--------------------------------

				$('#approve').modal('show');
			},

			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}
