<script>
			function ModelSubType(RequestNo) {

				// Constructing the URL using JavaScript
				 var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
			var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
			var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
			var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

			// Construct the full URL
			var url = '@Url.Action("DrillAddSubType", "DrillMaster")' +
				'?SubTypeId=' + RequestNo +
				'&PageID=' + pageID +
				'&ParentID=' + parentID +
				'&ModuleID=' + moduleID ;

			// Redirect
			window.location.href = url;
			}


				 function ModelSubTypeview(ID, RequestNo, FileTypeName, ProdLine, SizeType, SubTypeName, SKUCode, ImageFileName, Remark) {

		$('#txtID1').val(ID);
		$('#txtRequest3').text(RequestNo);
		$('#txtFileName3').text(FileTypeName);
		$('#txtSubtypeCode3').text(SubTypeName);
		$('#txtProdLine3').text(ProdLine);
		$('#txtremarklbl1').text(Remark ?? '');
		$('#txtFileSizeCode2').text(SizeType);
		$('#txtSkuCode2').text(SKUCode);

		var JsonData = JSON.stringify({
			Id: ID,
			ProductLineRowId: '',
			CTTypeRowId: ''
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetSubTypeTableData", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: "json",

			beforeSend: function () {
				$('#loader').show();
			},
			complete: function () {
				$('#loader').hide();
			},

			success: function (res) {

				let table = $('#tblSubTypeDataview');

				// ✅ Destroy old DataTable
				if ($.fn.DataTable.isDataTable('#tblSubTypeDataview')) {
					table.DataTable().clear().destroy();
				}

				let tbody = $("#tblSubTypeDataview tbody");
				tbody.empty();

				// ✅ IMAGE FIX
				if (ImageFileName) {
					OpenDocument(ImageFileName, 'displayImage2', ProdLine);
				}

				if (!res || !res.response || res.response.length === 0) {

					tbody.append(`
						<tr>
							<td colspan="6" class="text-center">
								No Data Found
							</td>
						</tr>
					`);

				} else {

					$.each(res.response, function (index, item) {

						tbody.append(`
							<tr>
								<td class="text-center">${item.sqNo}</td>
								<td class="text-wrap">${item.processName}</td>
								<td class="text-wrap">${item.parameterName}</td>
								<td class="text-center">${item.value ?? ''}</td>
								<td class="text-center">${item.uom ?? ''}</td>
								<td class="text-center">${item.tolerance ?? ''}</td>
							</tr>
						`);
					});
				}

				// ✅ Initialize DataTable
			let dt = table.DataTable({
		responsive: true,
		paging: true,
		pageLength: 10,
		lengthChange: true,
		searching: true,
		ordering: true,
		info: true,
		autoWidth: false,

		// ✅ ADD THIS (for layout)
		dom: "<'row'<'col-sm-2'l><'col-sm-4 text-center'B><'col-sm-6'f>>" +
			 "<'row'<'col-sm-12'tr>>" +
			 "<'row'<'col-sm-5'i><'col-sm-7'p>>",

		// ✅ ADD THIS (CSV button)
		buttons: [
			{
				extend: 'csv',
				text: 'CSV',
				className: 'btn btn-secondary btn-sm'
			}
		],

		columnDefs: [
			{ className: "dt-center", targets: [0, 3, 4, 5] }
		]
	});

				// ✅ Fix width issue inside modal
				$('#nonstandard1').off('shown.bs.modal').on('shown.bs.modal', function () {
					dt.columns.adjust();
				});

				// ✅ Show modal
				$('#nonstandard1').modal('show');
			},

			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}

			function ModelFileType(ID, RequestNo, FileTypeName, FileTypeCode, ProdLine, SizeType, SubTypeName, SKUCode, ImageFileName, Remark) {

		$('#txtID').val(ID);
