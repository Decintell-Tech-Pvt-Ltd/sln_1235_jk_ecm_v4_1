		$('#txtremarklbl').text(Remark ?? '');
		$('#txtFileSizeCode').text(SizeType);
		$('#txtSkuCode').text(SKUCode);

		var JsonData = JSON.stringify({
			Id: ID,
			ProductLineRowId: '',
			CTTypeRowId: ''
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetSubTypeTableData", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: "json",

			beforeSend: function () {
				$('#loader').show();
			},
			complete: function () {
				$('#loader').hide();
			},

			success: function (res) {

				let table = $('#tblSubTypeData');

				// ✅ Destroy existing DataTable
				if ($.fn.DataTable.isDataTable('#tblSubTypeData')) {
					table.DataTable().clear().destroy();
				}

				let tbody = $("#tblSubTypeData tbody");
				tbody.empty();

				// ✅ IMAGE FIX
				if (ImageFileName) {
					OpenDocument(ImageFileName, 'displayImage', ProdLine);
