                    <div class="card card-primary card-outline p-a-2" style="height: 100%;">

                        <!-- /.card-header -->
                        <div class="card-body">

                            <div class="col-md-12 mr-1">

                                <div class="row">

                                    <div class="form-group col-md-2">
                                        <label>Product Line</label>
                                        @Html.DropDownListFor(m => m.ProdId, new SelectList(Model.ProdLine_List, "Id", "ProductLine"), "Select", new { @class = "form-control select2", @id = "ddlproductline" })



                                    </div>


                                    <div class="form-group col-md-2">
                                        <label>Brand</label>
                                        @Html.DropDownListFor(m => m.BrandCode, new SelectList(Model.Brand_List, "BrandCode", "BrandName"), "Select", new { @class = "form-control select2", @id = "ddlBrand" })


                                    </div>



                                    <div class="form-group col-md-2">
                                        <label>Size </label>
                                        @Html.DropDownListFor(m => m.SizeID, new SelectList(Model.GetSizeList, "SizeID", "Size"), "Select", new { @class = "form-control select2", @id = "ddlSize", onchange = "clearError('spddlproductline')" })


                                    </div>


                                    <div class="form-group col-md-4">
                                        <label>Type </label>
                                        <select id="TxtFileType" class="form-control select2" >
