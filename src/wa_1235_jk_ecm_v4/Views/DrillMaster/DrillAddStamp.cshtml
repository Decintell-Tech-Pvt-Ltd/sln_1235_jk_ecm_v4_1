</div>
<script>
       async function  SaveStampDetails() {

        var ProductLineRowId = $("#ddlproductline").val();
        var BrandCode = $("#ddlBrand").val();
        var SizeRowId = $("#ddlSize").val();
        var CTTypeRowId = $("#TxtFileType").val();
        var SubTypeRowId = $("#dllCTFileSubType").val();
        var Sales = $("#dllFileSubType").val();

        var fileInput = document.getElementById("FileUploadIMG");
        var imageName = "";

        if (fileInput.files.length > 0) {
            imageName = fileInput.files[0].name;
        }

        var CreatedBy = parseInt('@Context.Session.GetInt32("CreatedBy")');
        var CreatedDate = moment.utc().format();
          let filenameIMG =
            ($('#FileUploadIMG')[0].files[0])
                ? $('#FileUploadIMG')[0].files[0].name
                : '';
        var JsonData = {
            ProductLineRowId: ProductLineRowId,
            CTTypeRowId: CTTypeRowId,
            SizeRowId: SizeRowId,
            SubTypeRowId: SubTypeRowId,
            BrandRowId: BrandCode,
            Sales: Sales,
            ImageName: imageName,
            CreatedBy: CreatedBy,
            CreatedDate: CreatedDate
        };

        var JSONInsert = JSON.stringify(JsonData);

        $.ajax({
            type: "POST",
            url: '@Url.Action("CT_AddStampDetail", "DrillMaster")',
            data: { JsonData: JSONInsert },
            dataType: "json",
            beforeSend: function () {
                $("#loader").show();
            },
            success:  async function (data)  {

           
                 if (data && data.response  === "Stamp details inserted successfully") {

                    let selectedImageNameSample =
                        cleanFileName(filenameIMG);

                            let targetPathSample =
            'others\\ct\\stamps\\' + BrandCode.toLowerCase();
           

                    let uploadedFileSample =
                        document.getElementById('FileUploadIMG').files[0];

                    await copyFile(
                        uploadedFileSample,
                        targetPathSample,
                        selectedImageNameSample
                    );

                    alert("Type added successfully.");

                   var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
    var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
    var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
    var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

    // Construct the full URL
    url = "@Url.Action("DrillStamp", "DrillMaster")" +
        "?PageID=" + pageID +
        "&ParentID=" + parentID +
        "&ModuleID=" + moduleID +
        "&ModulePageID=" + modulePageID;

    // Redirect
    window.location.href = url;
                }
                
               
                
            },
            error: function () {
                alert("Error while saving stamp details");
            },
            complete: function () {
                $("#loader").hide();
            }
        });

    }
         async function copyFile(fileInput, path, imageName) {
        var JwToken = '@ViewBag.JWTToken';
      var blobStorageUrl = '@ViewBag.ApiUrl';
      let blobPathPrefix = '@ViewBag.BaseBlobPath';
        var formdata = new FormData();
        // ✅ Append file correctly
        formdata.append("files", fileInput, imageName); // << change 'files' → 'file'

       // let blobPathPrefix = '@ViewBag.BaseBlobPath';
        blobPathPrefix = (blobPathPrefix || "").replace(/\\/g, "/").trim();
        if (blobPathPrefix.length > 0 && !blobPathPrefix.endsWith("/")) {
            blobPathPrefix += "/";
        }
        //    normalizePathPrefix(path)
        var Patths = blobPathPrefix + normalizePathPrefix(path.toLowerCase());
        formdata.append("blobPathPrefix", Patths);
        formdata.append("Policy", 0);


        $.ajax({
            url: blobStorageUrl + 'Files/upload',
            headers: {
                Authorization: 'Bearer ' + JwToken
            },
            method: "POST",
            contentType: false, // Not to set any content header
            processData: false, // Not to process data
            mimeType: "multipart/form-data",
            data: formdata,
            //async: false,
            success: function (result) {
                let jsonResult = JSON.parse(result); // serialize into JSON string
                if (jsonResult && jsonResult.length > 0) {
                    let json = {
                      //  UserId: parseInt(CreatedBy),
                        ImageName: imageName,
                        BlobJson: result,
                    };

                    var Jsons = JSON.stringify(json);
                    console.log(`uploading: ${Jsons}`);



                }

            },
            error: function (err) {
                alert(err.message);
            }
        });


    }
</script>