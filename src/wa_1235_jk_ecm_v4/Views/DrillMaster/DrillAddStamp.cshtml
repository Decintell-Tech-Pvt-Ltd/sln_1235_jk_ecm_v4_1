                                            }
                                        </select>
                                    </div>

                                    <div class="form-group col-md-2">
                                        <label>Sub Type </label>
                                        @Html.DropDownListFor(m => m.SubTypeId, new SelectList(Model.SubtypeDD, "SubTypeId", "SubTypeName"), "Select", new { @class = "form-control select2", @id = "dllCTFileSubType", onchange = "clearError('spCTddlSize');" })

                                    </div>



                                    <div class="form-group col-md-2">
                                        <label>Sales </label>
                                        <select class="form-control select2 select2-hidden-accessible" style="width: 100%;" tabindex="-1" aria-hidden="true" id="dllFileSubType">
                                            <option value="0">Select</option>

                                            <option value="1">Export</option>

                                            <option value="2">Domestic</option>
                                        </select>
                                    </div>



                                    @* <div class="col-md-2">
