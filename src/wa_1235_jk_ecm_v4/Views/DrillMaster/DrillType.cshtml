<script>


		$(document).ready(function () {
			// Hide the element with ID "txtID"
			$("#txtID").hide();

		});


	function setApproveItems(itemId, RequestNo, FileTypeName, FileTypeCode,ProdLine) {
		document.getElementById('approveItemId').textContent = itemId;

		ModelFileSize(itemId, RequestNo, FileTypeName, FileTypeCode,ProdLine);
		// OpenDocument(BrandCode, ImageFile, 'displayImage1');
	}

	function EditFileType(Id, RequestNo) {

		// Constructing the URL using JavaScript
		 var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
	var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
	var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
	var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');

	// Construct the full URL
	var url = '@Url.Action("DrillAddType", "DrillMaster")' +
		'?TypeId=' + encodeURIComponent(Id) +
		'&ReqId=' + encodeURIComponent(RequestNo) +
		'&PageID=' + pageID +
		'&ParentID=' + parentID +
		'&ModuleID=' + moduleID ;

	// Redirect
	window.location.href = url;
	}



	function ApproveFileType(Id, StatusId) {
		var iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
		var Remark=$('#txtRemark').val();
		var json = {
			Id: Id,
			StatusId: StatusId,
			Remark:Remark,
			CreatedDate: moment.utc(new Date()).format(),
			CreatedBy: iLoggedInUserID
		};
		var JsonData = JSON.stringify(json);


		$.ajax({
			type: "POST",
			url: '@Url.Action("DroApproveFileType", "DrillMaster")',
			data: { JsonData: JsonData },
			datatype: 'json',
			beforeSend: function () { $('#loader').show(); }, complete: function () { $('#loader').hide(); },
			success: function (data) {
				alert(data.response);
				location.reload();
			}
		});
	}




	function ModelOperation(ValueStreamCode, Id) {
		var JsonData = JSON.stringify({
			valuestreamcode: ValueStreamCode,
			id: Id
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetDroOperationList", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: 'json',
			beforeSend: function () { $('#loader').show(); },
			complete: function () { $('#loader').hide(); },
			success: function (data) {

				var html = '';


				for (var i = 0; i < data.operationList.length; i++) {
					html += '<tr>';
					html += '<td align="center">' + data.operationList[i].seqNo + '</td>';
					html += '<td align="center">' + data.operationList[i].opr_operation_name + '</td>';
					html += '</tr>';
				}
				$('#showAddedValueStreamProcess').html(html);
				$('#vscode').modal('show');
			},
			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}


	function ModelFileSize(ID, RequestNo, FileTypeName, FileTypeCode, ProdLine) {

		$('#txtID').val(ID);
		$('#txtRequest').text(RequestNo);
		$('#txtFileName').text(FileTypeName);
		$('#txtFileTypeCode').text(FileTypeCode);
		$('#txtProdLine').text(ProdLine);

		var JsonData = JSON.stringify({
			ID: ID
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetDroParametersList", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: 'json',
			beforeSend: function () { $('#loader').show(); },
			complete: function () { $('#loader').hide(); },

			success: function (data) {

				// 🔥 ONLY IMAGE BINDING LEFT
				var fileTypeProfileImage = "";

				if (data.parametersLists &&
					data.parametersLists.length > 0) {

					fileTypeProfileImage =
						data.parametersLists[0].fileTypeProfileImage;
				}

					OpenDocument(
		fileTypeProfileImage,
		'displayImage1',
		FileTypeCode
	);

				$('#approve').modal('show');
			},

			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}

	function ModelFileType(ID, RequestNo, FileTypeName, FileTypeCode, ProdLine, Remark) {

		document.getElementById('txtRequest1').textContent = RequestNo;
		document.getElementById('txtFileName1').textContent = FileTypeName;
		document.getElementById('txtFileTypeCode1').textContent = FileTypeCode;
		document.getElementById('txtProdLine1').textContent = ProdLine;
		document.getElementById('txtremarklbl').textContent = Remark;

		var JsonData = JSON.stringify({
			ID: ID
		});

		$.ajax({
			type: "POST",
			url: '@Url.Action("GetDroParametersList", "DrillMaster")',
			data: { JsonData: JsonData },
			dataType: 'json',
			beforeSend: function () { $('#loader').show(); },
			complete: function () { $('#loader').hide(); },

			success: function (data) {

				// 🔥 ONLY IMAGE BINDING LEFT
				var fileTypeProfileImage = "";

				if (data.parametersLists &&
					data.parametersLists.length > 0) {

					fileTypeProfileImage =
						data.parametersLists[0].fileTypeProfileImage;
				}

					OpenDocument(
		fileTypeProfileImage,
		'displayImage',
		FileTypeCode
	);

				$('#image').modal('show');
			},

			error: function () {
				alert('Error occurred while fetching data.');
			}
		});
	}
		async function OpenDocument(FileName, ImageId, FileTypeCode) {

	   var JwToken = '@ViewBag.JWTToken';
	   var blobStorageUrl = '@ViewBag.ApiUrl';
	   let blobPathPrefix = '@ViewBag.BaseBlobPath';

	   var path = 'others\\ct\\types\\';

	   const blobpath =
		   (normalizePathPrefix(blobPathPrefix) +
			normalizePathPrefix(path)).toLowerCase() + FileName;

	   const JSONData = {
		   blobPath: blobpath,
		   asSas: false,
		   downloadFileName: FileName
	   };

	   try {

		   $('#loader').show();

		   const response = await $.ajax({
			   url: blobStorageUrl + 'Files/get',
			   headers: { Authorization: 'Bearer ' + JwToken },
			   type: "POST",
			   contentType: "application/json",
			   data: JSON.stringify(JSONData),
			   xhrFields: { responseType: 'blob' }
		   });

		   if (response && response.size > 0) {

			   const objectURL = URL.createObjectURL(response);

			   const imgElement = document.getElementById(ImageId);
			   imgElement.src = objectURL;

		   }

	   } catch (error) {

		   console.error("Error:", error);

		   const imgElement = document.getElementById(ImageId);
		   imgElement.src = '';

	   } finally {

		   $('#loader').hide();

	   }
	}
</script>