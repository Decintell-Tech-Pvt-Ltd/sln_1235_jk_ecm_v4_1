     function readCSVFile() {

        var fileInput = document.getElementById("FileUploadCSV");

        if (fileInput.files.length === 0) {
            alert("Please select CSV file.");
            return;
        }

        var file = fileInput.files[0];
        var reader = new FileReader();

        reader.onload = function (e) {

            var csv = e.target.result;

            // split lines safely
            var rows = csv.split(/\r?\n/);

            var table = $('#tblCSVData').DataTable();

            table.clear();

            for (var i = 1; i < rows.length; i++) {

                if (!rows[i].trim()) continue;

                // basic split
                var cols = rows[i].split(",");

                if (cols.length < 8) continue;

                table.row.add([
                    cols[0]?.trim() || "",
                    cols[1]?.trim() || "",
                    cols[2]?.trim() || "",
                    cols[3]?.trim() || "",
                    cols[4]?.trim() || "",
                    cols[5]?.trim() || "",
                    cols[6]?.trim() || "",
                    cols[7]?.trim() || ""
                ]);
            }

            table.draw();
        };

        reader.readAsText(file);
    }
   function AddSubTypeData() {

    let ProductLineRowId = $("#ddlproductline").val();
    let CTTypeRowId = $("#TxtFileType").val();
    let SizeDetailsRowId = $("#ddlSize").val();
    let SubTypeName = $("#txtCustomer").val().trim();
    let SubTypeCode = $("#txtSubTypeCode").val().trim();
    let fileInput = document.getElementById("FileUploadCSV");
       let TxnId = parseInt($("#hdnSizeId").val()) || 0;
    let iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');
           let isValid = true;
            if (!ProductLineRowId || ProductLineRowId == "0") {
                $("#spddlproductline").text("Please select Product Line");
                isValid = false;
            }

            if (!CTTypeRowId || CTTypeRowId == "0") {
                        $("#spTxtFileType").text("Please select Type");
                isValid = false;
                }  
                         if (!SizeDetailsRowId || SizeDetailsRowId == "0") {
                    $("#spSize").text("Please select Product Line");
                    isValid = false;
                }

                        if (!SubTypeName || SubTypeName == "0") {
                                $("#sptxtCustomer").text("Please select Type");
                    isValid = false;
                }
                                  if (!SubTypeCode || SubTypeCode == "0") {
                                    $("#spSuttypecode").text("Please select Type");
                        isValid = false;
                    }
                  if (!isValid) return;
    if (!fileInput || fileInput.files.length === 0)
        return alert("Upload CSV file");

    let fileName = fileInput.files[0].name;   // ⭐ GET FILE NAME

    let reader = new FileReader();

    reader.onload = function (e) {

        let csvText = e.target.result.trim();
        let rows = csvText.split(/\r?\n/);

        let headers = rows[0].split(",").map(h => h.trim());
        let csvJson = [];

        for (let i = 1; i < rows.length; i++) {

            if (!rows[i].trim()) continue;

            let values = rows[i].split(",");
            let rowObj = {};

            for (let j = 0; j < headers.length; j++) {
                rowObj[headers[j]] =
                    values[j] ? values[j].trim() : "";
            }

            csvJson.push(rowObj);
        }

        // ⭐ Include CsvFileName
        let jsonData = {
                TxnId: parseInt(TxnId),
                ProductLineRowId: parseInt(ProductLineRowId),
            CTTypeRowId: parseInt(CTTypeRowId),
            SizeDetailsRowId: parseInt(SizeDetailsRowId),
            SubTypeCode: SubTypeCode,
            SubTypeName: SubTypeName,
            CsvFileName: fileName,   // ⭐ NEW FIELD
            CsvData: csvJson,
            CreatedBy: iLoggedInUserID,
            CreatedDate: moment.utc(new Date()).format()
        };

        $.ajax({
            type: "POST",
            url: '@Url.Action("AddSubType", "DrillMaster")',
            data: { JsonData: JSON.stringify(jsonData) },
            success: function (res) {
                alert(res.response);
               
            },
            error: function () {
                alert("Error while saving SubType.");
            }
        });
    };

    reader.readAsText(fileInput.files[0]);
}

        function onTypeChange() {

        var productLineId = $("#ddlproductline").val();
        var ctTypeRowId = $("#TxtFileType").val();

        if (!productLineId || !ctTypeRowId)
            return;

        /* -------------------------------------
           1️⃣ Existing Key Dimension Logic
        ------------------------------------- */

        var FileType = $("#TxtFileType option:selected").text().trim();
        var FileTypeCode = FileType.split('-').pop().trim();

        $("#hdnFileCode").val(FileTypeCode);

        var JsonDataKeyDim = JSON.stringify({
            TypeCode: FileTypeCode
        });

        $.ajax({
            type: "POST",
            url: '@Url.Action("GetCTKeyDimensionsByTypeCode", "DrillMaster")',
            data: { JsonData: JsonDataKeyDim },
            dataType: "json",
            success: function (data) {

                if (data && data.response && data.response.length > 0) {

                    var obj = data.response[0];

                    $("#spParamName").text(obj.paramName);
                    $("#spParamCode").text(obj.paramCode);
                    $("#spParamType").text(obj.paramType);
                }
            }
        });


        /* -------------------------------------
           2️⃣ Bind SubType Table
        ------------------------------------- */

        var JsonDataTable = JSON.stringify({
            ProductLineRowId: parseInt(productLineId),
            CTTypeRowId: parseInt(ctTypeRowId)
        });

        $.ajax({
            type: "POST",
            url: '@Url.Action("GetSubTypeTableData", "DrillMaster")',
            data: { JsonData: JsonDataTable },
            dataType: "json",

            beforeSend: function () {
                $('#loader').show();
            },
            complete: function () {
                $('#loader').hide();
            },

           success: function (res) {

        let table = $('#tblSubTypeData');

        // ✅ Destroy existing DataTable
        if ($.fn.DataTable.isDataTable(table)) {
            table.DataTable().clear().destroy();
        }

        let tbody = $("#tblSubTypeData tbody");
        tbody.empty();

        // ✅ No data case
        if (!res || !res.response || res.response.length === 0) {

            tbody.append(`
                <tr>
                    <td colspan="6" style="text-align:center;">
                        No Data Found
                    </td>
                </tr>
            `);

            // ⚠️ Still initialize DataTable (optional)
            table.DataTable({
                paging: true,
                searching: false,
                info: false
            });

            return;
        }

        // ✅ Bind data
        $.each(res.response, function (index, item) {

            tbody.append(`
                <tr>
                    <td style="text-align:center;">${item.sqNo}</td>
                    <td>${item.processName}</td>
                    <td>${item.parameterName}</td>
                    <td style="text-align:center;">${item.value ?? ''}</td>
                    <td style="text-align:center;">${item.uom ?? ''}</td>
                    <td style="text-align:center;">${item.tolerance ?? ''}</td>
                </tr>
            `);
        });

        // ✅ Initialize DataTable AFTER data load
        table.DataTable({
            responsive: true,
            paging: true,
            pageLength: 10,
            lengthChange: true,
            searching: true,
            ordering: true,
            info: true,
            autoWidth: false,

            columnDefs: [
                { className: "dt-center", targets: [0, 3, 4, 5] }
            ]
        });

        // ✅ Your existing function
        loadCTSizeDropdown();
    }
            });
    }

