<script>
           function SaveSizeData() {

        // success message
        alert("Sub Type details saved successfully");
              var pageID = encodeURIComponent('@Context.Request.Query["PageID"]');
        var parentID = encodeURIComponent('@Context.Request.Query["ParentID"]');
        var moduleID = encodeURIComponent('@Context.Request.Query["ModuleID"]');
        var modulePageID = encodeURIComponent('@Context.Request.Query["ModulePageID"]');
        // redirect
        var url = '@Url.Action("DrillSubType", "DrillMaster")' +
            '?PageID=' + pageID +
            '&ParentID=' + parentID +
            '&ModuleID=' + moduleID;

        window.location.href = url;
    }
     function readCSVFile() {

        var fileInput = document.getElementById("FileUploadCSV");

        if (fileInput.files.length === 0) {
            alert("Please select CSV file.");
            return;
        }

        var file = fileInput.files[0];
        var reader = new FileReader();

        reader.onload = function (e) {

            var csv = e.target.result;

            // split lines safely
            var rows = csv.split(/\r?\n/);

            var table = $('#tblCSVData').DataTable();

            table.clear();

            for (var i = 1; i < rows.length; i++) {

                if (!rows[i].trim()) continue;

                // basic split
                var cols = rows[i].split(",");

                if (cols.length < 8) continue;

                table.row.add([
                    cols[0]?.trim() || "",
                    cols[1]?.trim() || "",
                    cols[2]?.trim() || "",
                    cols[3]?.trim() || "",
                    cols[4]?.trim() || "",
                    cols[5]?.trim() || "",
                    cols[6]?.trim() || "",
                    cols[7]?.trim() || ""
                ]);
            }

            table.draw();
        };

        reader.readAsText(file);
    }
   function AddSubTypeData() {

    let ProductLineRowId = $("#ddlproductline").val();
    let CTTypeRowId = $("#TxtFileType").val();
    let SizeDetailsRowId = $("#ddlSize").val();
    let SubTypeName = $("#txtCustomer").val().trim();
    let SubTypeCode = $("#txtSubTypeCode").val().trim();
    let fileInput = document.getElementById("FileUploadCSV");

    let iLoggedInUserID = parseInt('@Context.Session.GetInt32("CreatedBy")');

    if (!fileInput || fileInput.files.length === 0)
        return alert("Upload CSV file");

    let fileName = fileInput.files[0].name;   // ⭐ GET FILE NAME

    let reader = new FileReader();

    reader.onload = function (e) {

        let csvText = e.target.result.trim();
        let rows = csvText.split(/\r?\n/);

        let headers = rows[0].split(",").map(h => h.trim());
        let csvJson = [];

        for (let i = 1; i < rows.length; i++) {

            if (!rows[i].trim()) continue;

            let values = rows[i].split(",");
            let rowObj = {};

            for (let j = 0; j < headers.length; j++) {
                rowObj[headers[j]] =
                    values[j] ? values[j].trim() : "";
            }

            csvJson.push(rowObj);
        }

        // ⭐ Include CsvFileName
        let jsonData = {
            ProductLineRowId: parseInt(ProductLineRowId),
            CTTypeRowId: parseInt(CTTypeRowId),
            SizeDetailsRowId: parseInt(SizeDetailsRowId),
            SubTypeCode: SubTypeCode,
            SubTypeName: SubTypeName,
            CsvFileName: fileName,   // ⭐ NEW FIELD
            CsvData: csvJson,
            CreatedBy: iLoggedInUserID,
            CreatedDate: moment.utc(new Date()).format()
        };

        $.ajax({
            type: "POST",
            url: '@Url.Action("AddSubType", "DrillMaster")',
            data: { JsonData: JSON.stringify(jsonData) },
            success: function (res) {
                alert(res.response || "SubType inserted successfully");
                location.reload();
            },
            error: function () {
                alert("Error while saving SubType.");
            }
        });
    };

    reader.readAsText(fileInput.files[0]);
}
